<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ═══ TOP TOOLBAR ═══ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/surface"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Space Indicator -->
        <LinearLayout
            android:id="@+id/space_indicator"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:background="@drawable/space_indicator_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/space_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/circle"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/space_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxWidth="100dp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <!-- URL Bar -->
        <EditText
            android:id="@+id/url_bar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/url_bar_bg"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:hint="Search or enter URL"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:singleLine="true"
            android:selectAllOnFocus="true"/>

        <!-- Reload Button -->
        <ImageView
            android:id="@+id/btn_reload"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="Reload"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ═══ PROGRESS BAR ═══ -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:visibility="gone"
        android:progressTint="@color/accent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ═══ GECKOVIEW (Browser) ═══ -->
    <org.mozilla.geckoview.GeckoView
        android:id="@+id/gecko_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/progress_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ═══ BOTTOM TOOLBAR ═══ -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/surface"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back"
            android:alpha="0.3"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btn_forward"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Forward"
            android:alpha="0.3"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btn_new_tab"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="New Tab"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btn_tabs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Tabs"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btn_spaces"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:contentDescription="Spaces"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
