<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- SpaceBrowser Dark Theme — Material Design 3 -->
    <style name="Theme.SpaceBrowser" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryContainer">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Bottom sheet -->
        <item name="bottomSheetDialogTheme">@style/SpaceBrowser.BottomSheet</item>
    </style>

    <style name="SpaceBrowser.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/SpaceBrowser.BottomSheetStyle</item>
    </style>

    <style name="SpaceBrowser.BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/surface</item>
        <item name="shapeAppearance">@style/SpaceBrowser.BottomSheetShape</item>
    </style>

    <style name="SpaceBrowser.BottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
    </style>
</resources>
