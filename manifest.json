{
  "manifest_version": 2,
  "name": "SpaceBrowser",
  "version": "0.1.0",
  "description": "Fully isolated browsing spaces with unique anti-fingerprinting per space. Each space is a separate browser — zero data sharing.",
  "author": "Mr. Aman",

  "permissions": [
    "contextualIdentities",
    "cookies",
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "browsingData",
    "<all_urls>"
  ],

  "background": {
    "scripts": [
      "src/space-manager/space-store.js",
      "src/anti-fingerprint/fingerprint-generator.js",
      "src/space-manager/space-manager.js",
      "src/background.js"
    ],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/anti-fingerprint/fingerprint-injector.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "sidebar_action": {
    "default_title": "SpaceBrowser — Spaces",
    "default_panel": "src/ui/spaces-sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Toggle SpaceBrowser Sidebar"
  },

  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle SpaceBrowser sidebar"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
