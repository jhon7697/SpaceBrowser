# WHERE TO FIND KEY FUNCTIONS:
#   - Line ~150: IsResistFingerprintingEnabled()
#   - Line ~300: GetSpoofedUserAgent()
#   - Line ~500: ReduceTimePrecision() — timestamp fuzzing
#
# WHAT WE CHANGE:
#   Add the per-space profile cache and lookup implementation.
#   Add the canvas noise application function.
#   Make GetSpoofedUserAgent() accept an optional userContextId.
#

--- a/toolkit/components/resistfingerprinting/nsRFPService.cpp
+++ b/toolkit/components/resistfingerprinting/nsRFPService.cpp
@@ -45,6 +45,10 @@
+#include "SpaceIdentityService.h"  // Our JSM bridge header
+
 using namespace mozilla;

+// Static member initialization
+std::unordered_map<uint32_t, SpaceFingerprintProfile> nsRFPService::sSpaceProfiles;
+mozilla::Mutex nsRFPService::sProfilesMutex("nsRFPService::sProfilesMutex");
+
 // --------------------------------------------------------------------------
 // Per-Space Profile Management
 // --------------------------------------------------------------------------

+/* static */
+bool nsRFPService::HasSpaceProfile(uint32_t aUserContextId) {
+  MutexAutoLock lock(sProfilesMutex);
+  return sSpaceProfiles.find(aUserContextId) != sSpaceProfiles.end();
+}
+
+/* static */
+const SpaceFingerprintProfile* nsRFPService::GetSpaceProfile(
+    uint32_t aUserContextId) {
+  MutexAutoLock lock(sProfilesMutex);
+  auto it = sSpaceProfiles.find(aUserContextId);
+  if (it != sSpaceProfiles.end()) {
+    return &it->second;
+  }
+  return nullptr;
+}
+
+/* static */
+void nsRFPService::RegisterSpaceProfile(
+    const SpaceFingerprintProfile& aProfile) {
+  MutexAutoLock lock(sProfilesMutex);
+  sSpaceProfiles[aProfile.userContextId] = aProfile;
+
+  MOZ_LOG(gResistFingerprintingLog, LogLevel::Info,
+          ("Registered fingerprint profile for container %u",
+           aProfile.userContextId));
+}
+
+/* static */
+void nsRFPService::UnregisterSpaceProfile(uint32_t aUserContextId) {
+  MutexAutoLock lock(sProfilesMutex);
+  sSpaceProfiles.erase(aUserContextId);
+
+  MOZ_LOG(gResistFingerprintingLog, LogLevel::Info,
+          ("Unregistered fingerprint profile for container %u",
+           aUserContextId));
+}
+
+/**
+ * Apply deterministic noise to canvas pixel data.
+ *
+ * This is the core of per-space canvas fingerprinting. We use the space's
+ * noise seed to generate reproducible pixel modifications. The noise is
+ * subtle enough to be invisible to humans but changes the canvas hash.
+ *
+ * Algorithm:
+ *   For each pixel, use a seeded PRNG (Mulberry32) to generate a small
+ *   offset (-amplitude to +amplitude) and add it to each color channel.
+ *   The seed incorporates both the space's seed and the pixel position,
+ *   making the noise deterministic and unique per space.
+ */
+/* static */
+void nsRFPService::ApplyCanvasNoise(uint8_t* aData, uint32_t aLength,
+                                     uint32_t aSeed, float aAmplitude) {
+  if (!aData || aLength == 0 || aAmplitude == 0.0f) {
+    return;
+  }
+
+  // Mulberry32 PRNG — same algorithm as our JS implementation
+  auto mulberry32 = [](uint32_t& state) -> float {
+    state += 0x6D2B79F5;
+    uint32_t t = state;
+    t = (t ^ (t >> 15)) * (t | 1);
+    t ^= t + (t ^ (t >> 7)) * (t | 61);
+    return static_cast<float>((t ^ (t >> 14)) >> 0) / 4294967296.0f;
+  };
+
+  uint32_t state = aSeed;
+  const int maxOffset = static_cast<int>(aAmplitude * 255.0f);
+
+  // Process RGBA pixel data (4 bytes per pixel)
+  for (uint32_t i = 0; i < aLength; i += 4) {
+    // Only modify RGB channels, leave alpha untouched
+    for (int c = 0; c < 3; c++) {
+      float rand = mulberry32(state);
+      int offset = static_cast<int>((rand * 2.0f - 1.0f) * maxOffset);
+      int newVal = static_cast<int>(aData[i + c]) + offset;
+      // Clamp to [0, 255]
+      aData[i + c] = static_cast<uint8_t>(std::clamp(newVal, 0, 255));
+    }
+  }
+}


