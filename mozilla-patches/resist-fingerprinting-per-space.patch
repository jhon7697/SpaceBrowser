# FILE 2: toolkit/components/resistfingerprinting/nsRFPService.cpp
# =============================================================================
#
# WHAT IT DOES NOW:
#   Implements the global RFP service. Key methods:
#   - IsResistFingerprintingEnabled() — checks the single global pref
#   - GetSpoofedUserAgent() — returns a generic spoofed UA
#   - Various spoofing utilities (timezone, locale, etc.)
