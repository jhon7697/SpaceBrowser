 /**
  * AudioBufferAddNoise — adds noise to audio buffer for anti-fingerprinting.
  *
  * ORIGINAL BEHAVIOR:
  *   When RFP is enabled globally, this adds random noise using a global
  *   random seed. All containers get the same noise pattern.
  *
  * SPACEBROWSER BEHAVIOR:
  *   Each Space gets deterministic noise from its own seed. This means:
  *   - Same Space always produces the same audio fingerprint (consistent)
  *   - Different Spaces produce different fingerprints (unique)
  *   - The noise is subtle enough not to be audible
  */
 void AudioBufferAddNoise(float* aBuffer, uint32_t aLength,
+                          uint32_t aUserContextId) {
