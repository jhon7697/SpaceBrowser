+  const SpaceFingerprintProfile* profile =
+      nsRFPService::GetSpaceProfile(aUserContextId);
+
+  if (profile) {
+    // Use per-space deterministic noise
+    uint32_t seed = profile->audioNoiseSeed;
+    float amplitude = profile->audioNoiseAmplitude;
+
+    // Mulberry32 PRNG (same as canvas noise)
+    auto mulberry32 = [](uint32_t& state) -> float {
+      state += 0x6D2B79F5;
+      uint32_t t = state;
+      t = (t ^ (t >> 15)) * (t | 1);
+      t ^= t + (t ^ (t >> 7)) * (t | 61);
+      return static_cast<float>((t ^ (t >> 14)) >> 0) / 4294967296.0f;
+    };
